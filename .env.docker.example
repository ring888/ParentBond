# Copy this file to .env before running docker compose.

TZ=Asia/Shanghai
WEB_PORT=8080

# Use strong passwords in real deployments.
MYSQL_ROOT_PASSWORD=change_this_root_password
MYSQL_DATABASE=parentbond
MYSQL_USER=parentbond
MYSQL_PASSWORD=change_this_password

# Local single-machine deployment:
VITE_API_BASE_URL=http://localhost:8080/api/v1
WEB_ORIGIN=http://localhost:8080,http://127.0.0.1:8080

# LAN example:
# VITE_API_BASE_URL=http://192.168.168.51:8080/api/v1
# WEB_ORIGIN=http://192.168.168.51:8080

# HTTPS/domain example:
# VITE_API_BASE_URL=https://parentbond.example.com/api/v1
# WEB_ORIGIN=https://parentbond.example.com

AI_DEFAULT_PROVIDER=mimo
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
CLAUDE_API_KEY=
CLAUDE_MODEL=claude-sonnet-4-6
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat
MIMO_API_KEY=
MIMO_BASE_URL=https://api.xiaomimimo.com/v1
MIMO_MODEL=mimo-v2.5-pro
